{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "iDot Matrix LED config schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ip": { "type": "string", "description": "IP or MAC address of the iDot device" },
    "token": { "type": "string", "description": "Nightscout API token (sensitive)" },
    "url": { "type": "string", "format": "uri", "description": "Nightscout base URL" },
    "output type": {
      "type": "string",
      "enum": ["gif", "image"],
      "description": "Use 'gif' for animated output or 'image' for single image"
    },
    "image out": {
      "type": "string",
      "enum": ["pc", "led matrix"],
      "description": "Where to send generated image"
    },
    "os": { "type": "string", "enum": ["windows", "linux", "mac"], "description": "Operating system" },
    "show_time": { "type": "boolean", "description": "Whether to render time on the image" },
    "time_format": {
      "type": "string",
      "enum": ["24h", "12h", "HH:MM", "HH:MM:SS", "compact", "MM:SS"],
      "description": "Time format to use (24h or 12h or legacy tokens)"
    },
    "time_position": {
      "type": "string",
      "enum": ["top-right", "top-left", "bottom-left", "bottom-right", "bottom"],
      "description": "Where to place time on the matrix"
    },
    "time_color_fade": { "type": "number", "minimum": 0, "maximum": 1 },
    "plot glucose intervals": { "type": "boolean" },
    "low boundary glucose": { "type": "integer" },
    "high boundary glucose": { "type": "integer" },
    "night_brightness": { "type": "number", "minimum": 0, "maximum": 100 },
    "PIXEL_INTERVAL": { "type": "integer", "minimum": 1, "description": "minutes per pixel" }
  },
  "required": ["token", "url", "output type"]
}
